# ── Cloudbox VAR Hunter — Environment Variables ──────────────────────────────
#
# Copy this file to .env.local for local development.
# This app runs entirely locally — no cloud database required.

# ── REQUIRED API KEYS ─────────────────────────────────────────────────────────

# Anthropic (Claude) — get at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Serper (Google Search) — get at serper.dev (free: 2,500 searches/month)
SERPER_API_KEY=...

# ── OPTIONAL: CRON SECURITY ───────────────────────────────────────────────────
# Random secret to authenticate Vercel cron job requests.
# Generate one with: openssl rand -hex 32
CRON_SECRET=change-this-to-a-random-string

# ── OPTIONAL: TEAMS NOTIFICATIONS ────────────────────────────────────────────
# Teams channel → Manage channel → Connectors → Incoming Webhook
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/...

# ── OPTIONAL: EMAIL DELIVERY ──────────────────────────────────────────────────
ENABLE_EMAIL_DELIVERY=false

# Resend (email) — get at resend.com
RESEND_API_KEY=re_...

# Where to deliver reports
REPORT_TO_EMAIL=you@yourcompany.com

# Sender address (must be a verified domain in Resend)
RESEND_FROM=reports@yourcompany.com
