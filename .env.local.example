# ─── REQUIRED ────────────────────────────────────────────────
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Get from: serper.dev (free tier: 2,500 searches/month)
SERPER_API_KEY=your-serper-key-here

# ─── REQUIRED IN PRODUCTION ──────────────────────────────────
# Any random secret string — protects /api/cron, /api/backfill, /api/refresh-knowledge
# Generate one with: openssl rand -hex 32
CRON_SECRET=change-this-to-a-random-string

# ─── OPTIONAL: TEAMS NOTIFICATIONS ───────────────────────────
# Get from: Teams channel → Manage channel → Connectors → Incoming Webhook
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/...

# ─── OPTIONAL: EMAIL DELIVERY ────────────────────────────────
# Set to true to enable email delivery via Resend (default: false)
ENABLE_EMAIL_DELIVERY=false

# Required when ENABLE_EMAIL_DELIVERY=true
# Get from: resend.com
RESEND_API_KEY=re_...

# Required when ENABLE_EMAIL_DELIVERY=true — where to send reports
REPORT_TO_EMAIL=you@yourcompany.com

# Optional — sender address (must be a verified domain in Resend)
# Defaults to: reports@cloudboxapp.com
RESEND_FROM=reports@cloudboxapp.com
