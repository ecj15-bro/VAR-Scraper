# ─── REQUIRED ───────────────────────────────────────────────
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Get from: serper.dev (free: 2,500 searches/month)
SERPER_API_KEY=your-serper-key-here

# Get from: Microsoft Teams channel → Manage channel → Connectors → Incoming Webhook
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/...

# Any random secret string — used to protect the cron endpoint
CRON_SECRET=change-this-to-a-random-string
