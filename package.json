{
  "name": "cloudbox-var-hunter",
  "version": "0.1.0",
  "description": "Multi-agent VAR partner prospecting pipeline",
  "author": "Cloudbox",
  "private": true,
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pipeline": "tsx scripts/run-pipeline.ts",
    "pipeline:dry": "tsx scripts/run-pipeline.ts --dry-run",
    "pipeline:backfill": "tsx scripts/run-pipeline.ts --backfill",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && electron-builder --dir",
    "electron:pack": "node scripts/zip-dist.js"
  },
  "build": {
    "appId": "com.cloudbox.varhunter",
    "productName": "Cloudbox VAR Hunter",
    "directories": {
      "output": "dist"
    },
    "files": [
      ".next/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "forceCodeSigning": false,
    "win": {
      "target": "dir",
      "icon": "electron/icon.ico",
      "forceCodeSigning": false
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "docx": "^9.6.1",
    "electron-is-dev": "^3.0.1",
    "electron-store": "^11.0.2",
    "exceljs": "^4.4.0",
    "get-port": "^7.2.0",
    "next": "14.2.5",
    "pdfkit": "^0.18.0",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
